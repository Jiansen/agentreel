[Unit]
Description=AgentReel Task Daemon (queue-based task executor)
After=network.target openclaw-gateway.service
Wants=agentreel-relay.service

[Service]
Type=simple
ExecStart=/bin/bash -c '. $HOME/.agentreel/lib/config.sh && exec bash $HOME/.agentreel/deploy/task_daemon.sh'
Restart=always
RestartSec=10
Environment=HOME=/home/ubuntu
EnvironmentFile=-/home/ubuntu/.agentreel/config.env
WorkingDirectory=/home/ubuntu
User=ubuntu
KillMode=mixed
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
