# AgentReel Configuration
# Copy to ~/.agentreel/config.env and edit.
# All values shown are defaults — uncomment and change as needed.

# ── Paths ──────────────────────────────────────────────────
# AGENTREEL_DIR="$HOME/.agentreel"
# AGENTREEL_WATCH_DIR="$HOME/.openclaw/agents/main/sessions/"
# AGENTREEL_CHROME_DIR="$HOME/.config/agentreel-chrome"

# ── Ports ──────────────────────────────────────────────────
# AGENTREEL_PORT=3000
# AGENTREEL_RELAY_PORT=8765
# AGENTREEL_CDP_PORT=18802
# AGENTREEL_VNC_WS_PORT=6080
# AGENTREEL_VNC_RFB_PORT=5999

# ── Display ────────────────────────────────────────────────
# AGENTREEL_DISPLAY=:99
# AGENTREEL_BROADCAST_DISPLAY=:100
# AGENTREEL_RESOLUTION=1920x1080
# AGENTREEL_NO_DESKTOP=0

# ── Streaming ──────────────────────────────────────────────
# AGENTREEL_BITRATE=4500k
# AGENTREEL_MAXRATE=6000k
# AGENTREEL_FPS=30

# ── Stream keys (set these to enable streaming) ────────────
# YT_STREAM_KEY=your-youtube-stream-key
# TW_STREAM_KEY=your-twitch-stream-key
